generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FOUNDER
  MENTOR
  INVESTOR
  ADMIN
}

enum OnboardingStatus {
  BASIC
  ROLE_PROFILE
  COMPLETED
}

enum VerificationType {
  EMAIL
  PHONE
}

enum FeedAttachmentKind {
  IMAGE
  VIDEO
  LINK
}

enum ProfileApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  phoneNumber     String?          @unique
  country         String?
  location        String?
  joinAim         String?
  aboutYourself   String?
  experienceLevel String?
  linkedinUrl     String?
  primaryGoal     String?
  passwordHash    String
  role            UserRole         @default(FOUNDER)
  onboardingStatus OnboardingStatus @default(BASIC)
  /** Profile photo (avatar), like LinkedIn / Instagram. */
  image           String?
  /** Wide cover image behind the avatar on member profile. */
  coverImageUrl   String?
  profileApprovalStatus ProfileApprovalStatus @default(APPROVED)
  profileApprovalNote   String? @db.Text
  emailVerified   DateTime?
  phoneVerifiedAt DateTime?
  /** Set when user saves the post-onboarding extended profile (all sections). */
  extendedProfileCompletedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  founderProfile  FounderProfile?
  mentorProfile   MentorProfile?
  investorProfile InvestorProfile?
  verificationCodes VerificationCode[]
  feedPosts       FeedPost[]
  feedComments    FeedComment[]
  following       UserFollow[]     @relation("Following")
  followers       UserFollow[]     @relation("Followers")
}

model FeedPost {
  id          String           @id @default(cuid())
  authorId    String
  body        String           @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments FeedAttachment[]
  comments    FeedComment[]

  @@index([createdAt])
  @@index([authorId])
}

model FeedAttachment {
  id     String             @id @default(cuid())
  postId String
  url    String
  kind   FeedAttachmentKind
  post   FeedPost           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model VerificationCode {
  id         String           @id @default(cuid())
  userId     String
  type       VerificationType
  code       String
  expiresAt  DateTime
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model RegistrationVerification {
  id         String   @id @default(cuid())
  email      String   @unique
  phone      String
  emailCode  String
  phoneCode  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FounderProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  startupName    String
  stage          String
  industry       String
  teamSize       String?
  traction       String?
  fundingNeeded  String?
  industryExpertiseNarrative String? @db.Text
  studyWorkBackground        String? @db.Text
  achievements               String? @db.Text
  investmentCapital          String? @db.Text
  investmentInterest         String? @db.Text
  investmentHistory          String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MentorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  yearsExperience   Int
  domainExpertise   String
  pastCompanies     String?
  mentoringStyle    String?
  availability      String?
  industryExpertiseNarrative String? @db.Text
  studyWorkBackground        String? @db.Text
  achievements               String? @db.Text
  investmentCapital          String? @db.Text
  investmentInterest         String? @db.Text
  investmentHistory          String? @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvestorProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  firmName             String
  checkSizeRange       String
  investmentStage      String
  sectorsOfInterest    String
  preferredGeography   String?
  industryExpertiseNarrative String? @db.Text
  studyWorkBackground        String? @db.Text
  achievements               String? @db.Text
  investmentCapital          String? @db.Text
  investmentInterest         String? @db.Text
  investmentHistory          String? @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
